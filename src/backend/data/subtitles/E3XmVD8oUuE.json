[
  {
    "start": "00:02",
    "text": "[음악]"
  },
  {
    "start": "00:02",
    "text": "안녕하세요"
  },
  {
    "start": "00:04",
    "text": "혼자 공부하는 파이썬 79강입니다"
  },
  {
